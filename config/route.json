{
  "domainStrategy": "IPIfNonMatch",
  "rules": [
    {
      "outboundTag": "block",
      "ip": [
        "geoip:private"
      ]
    },
    {
      "outboundTag": "block",
      "protocol": [
        "bittorrent"
      ]
    },
    {
      "domain": [
        "geosite:google,youtube,telegram,gfw"
      ],
      "outboundTag": "IPv4_out"
    },
    {
        "type": "field",
        "outboundTag": "socks5",
        "domain": [
            "geosite:netflix",
            "geosite:openai"
        ]
    },
    {
      "domain": [
        "geosite:cn"
      ],
      "outboundTag": "warp"
    },
    {
      "ip": [
        "geoip:cn"
      ],
      "outboundTag": "warp"
    },
    {
      "outboundTag": "IPv4_out",
      "network": "udp,tcp"
    }
  ]
}
